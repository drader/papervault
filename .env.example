VAULT_PATH=./wiki

# ── LLM (research modülü için) ────────────────────────────────────────────────
# Provider seçenekleri: anthropic | openai | google | deepseek | llama | grok
LLM_PROVIDER=anthropic
LLM_API_KEY=your_api_key_here

# Optional: varsayılan modeli geçersiz kıl
# Varsayılanlar: anthropic=claude-haiku-4-5-20251001, openai=gpt-4o-mini, google=gemini-1.5-flash
# LLM_MODEL=

# ── Search (research modülü için) ────────────────────────────────────────────
# Optional: improves Semantic Scholar rate limits
# SEMANTIC_SCHOLAR_API_KEY=

# ── Fetcher ───────────────────────────────────────────────────────────────────
# Adapter enable/disable ve cascade ayarları: sources-config.example.json → sources-config.json
